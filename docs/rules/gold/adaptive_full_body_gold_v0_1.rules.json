{
  "rule_set_id": "adaptive_full_body_gold_v0_1_rules",
  "version": "0.1.0",
  "program_scope": ["adaptive_full_body_gold_v0_1"],
  "source_pdf": "reference/The_Pure_Bodybuilding_Program - Phase 1 - Full_Body.pdf",
  "starting_load_rules": {
    "method": "conservative_top_set",
    "default_rir_target": 2,
    "fallback_percent_estimated_1rm": 72
  },
  "progression_rules": {
    "success_condition": "all_work_sets_reach_top_rep_within_rir",
    "on_success": { "action": "increase_load", "percent": 2.5 },
    "on_in_range": { "action": "hold_load_chase_reps" },
    "on_under_target": { "action": "hold_or_reduce", "reduce_percent": 2.5, "after_exposures": 2 }
  },
  "fatigue_rules": {
    "high_fatigue_trigger": {
      "conditions": [
        "session_rpe_avg >= 9",
        "under_target_exposures >= 2"
      ]
    },
    "on_high_fatigue": {
      "action": "reduce_volume",
      "set_delta": -1
    }
  },
  "deload_rules": {
    "scheduled_every_n_weeks": 6,
    "early_deload_trigger": "three_consecutive_under_target_sessions",
    "on_deload": {
      "set_reduction_percent": 35,
      "load_reduction_percent": 10
    }
  },
  "substitution_rules": {
    "equipment_mismatch": "use_first_compatible_substitution",
    "repeat_failure_trigger": "switch_after_three_failed_exposures"
  },
  "rationale_templates": {
    "increase_load": "Performance exceeded target. Increase load next exposure.",
    "hold_load": "Performance met target range. Hold load and chase rep ceiling.",
    "reduce_load": "Performance repeatedly below target. Reduce load to restore quality.",
    "deload": "Fatigue/stall criteria met. Deload to restore readiness."
  }
}
